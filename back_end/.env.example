PORT=1025
WS_PORT=8080

PGHOST=localhost
PGPORT=5432
PGDATABASE=punc
PGUSER=postgres
PGPASSWORD=
SENHA_SECRETA=

JWT_SECRET=

# Firebase Admin (escolha uma das opções abaixo)
# Opção 1: caminho para o JSON da service account
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# Opção 2: JSON inline (útil em deploy)
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}

# Opção 3: variáveis separadas
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY=

# Notificações de coleta (motorista -> células no raio)
# NOTIFICACAO_RAIO_M=1000
# NOTIFICACAO_INTERVALO_MIN=30
